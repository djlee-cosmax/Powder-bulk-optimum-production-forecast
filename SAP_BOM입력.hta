<html>
<head>
<title>SAP BOM 조회</title>
<HTA:APPLICATION
  ID="oHTA"
  APPLICATIONNAME="SAP BOM 조회"
  BORDER="dialog"
  BORDERSTYLE="normal"
  INNERBORDER="no"
  CAPTION="yes"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="no"
  SCROLL="no"
  SINGLEINSTANCE="yes"
  SYSMENU="yes"
/>
<style>
  body { font-family: Malgun Gothic, sans-serif; margin: 0; padding: 16px; background: #f7f8fa; }
  h2 { font-size: 16px; margin: 0 0 4px; color: #1a1a1a; }
  .sub { font-size: 12px; color: #999; margin-bottom: 12px; }

  .paste-section {
    margin-bottom: 12px; padding: 10px;
    background: #fff; border: 1px solid #e0e0e0; border-radius: 8px;
  }
  .paste-title { font-size: 12px; font-weight: 700; color: #333; margin-bottom: 4px; }
  .paste-help { font-size: 11px; color: #888; margin-bottom: 6px; }
  .paste-area {
    width: 100%; height: 64px; padding: 6px 8px;
    border: 1px solid #ddd; border-radius: 5px;
    font-family: Consolas, monospace; font-size: 12px;
    box-sizing: border-box; resize: none;
  }
  .paste-row { display: flex; gap: 6px; margin-top: 6px; align-items: center; }
  .paste-btn {
    padding: 6px 14px; background: #2563eb; color: #fff;
    border: none; border-radius: 5px; font-size: 12px; cursor: pointer;
  }
  .paste-btn:hover { background: #1d4ed8; }
  .paste-clear {
    padding: 6px 12px; background: #fff; color: #666;
    border: 1px solid #ccc; border-radius: 5px; font-size: 12px; cursor: pointer;
  }

  .header-row {
    display: flex; gap: 6px; margin-bottom: 6px; padding-left: 26px;
  }
  .lbl { font-size: 11px; color: #999; font-weight: 600; }

  #rowsContainer {
    height: 220px; overflow-y: auto;
    background: #fff; border: 1px solid #e0e0e0; border-radius: 8px;
    padding: 8px;
  }
  .row { display: flex; gap: 6px; margin-bottom: 5px; align-items: center; }
  .row-num {
    font-weight: 700; font-size: 12px; color: #888;
    min-width: 22px; text-align: center;
  }
  .row input {
    box-sizing: border-box;
    height: 28px; line-height: 26px;
    padding: 0 9px; margin: 0;
    border: 1px solid #ddd; border-radius: 5px;
    font-size: 13px; font-family: Malgun Gothic, sans-serif;
    vertical-align: middle;
  }
  .code-input { width: 120px; }
  .name-input { width: 180px; }
  .qty-input { width: 90px; text-align: right; }
  .row-del {
    box-sizing: border-box;
    height: 28px; padding: 0 9px;
    border: 1px solid #fca5a5; background: #fff;
    color: #dc2626; border-radius: 5px; font-size: 14px;
    cursor: pointer; line-height: 26px;
  }
  .row-del:hover { background: #fee2e2; }

  .add-row-wrap { margin-top: 8px; }
  .add-row-btn {
    padding: 7px 16px; background: #fff; border: 1px dashed #aaa;
    color: #555; border-radius: 6px; font-size: 12px; cursor: pointer;
  }
  .add-row-btn:hover { background: #f0f0f0; }

  .btns { margin-top: 14px; display: flex; gap: 8px; }
  .btn { padding: 9px 24px; border: none; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer; }
  .btn-ok { background: #1a1a1a; color: #fff; }
  .btn-cancel { background: #e0e0e0; color: #333; }
</style>

<script language="VBScript">
  Dim rowSeq
  rowSeq = 0

  Sub Window_onLoad
    window.resizeTo 580, 640
    Dim sw, sh, n
    sw = window.screen.availWidth
    sh = window.screen.availHeight
    window.moveTo (sw - 580) / 2, (sh - 640) / 2
    For n = 1 To 5
      AddRow
    Next
    document.getElementById("pasteArea").focus
  End Sub

  Sub Window_onUnload
    Dim fso2, wshShell2, flagPath2
    Set fso2 = CreateObject("Scripting.FileSystemObject")
    Set wshShell2 = CreateObject("WScript.Shell")
    flagPath2 = wshShell2.ExpandEnvironmentStrings("%TEMP%") & "\bom_done.flag"
    If Not fso2.FileExists(flagPath2) Then
      Dim tempCheck
      tempCheck = wshShell2.ExpandEnvironmentStrings("%TEMP%") & "\bom_input.txt"
      If Not fso2.FileExists(tempCheck) Then
        Dim ff2
        Set ff2 = fso2.CreateTextFile(flagPath2, True)
        ff2.WriteLine "cancel"
        ff2.Close
        Set ff2 = Nothing
      End If
    End If
    Set fso2 = Nothing
    Set wshShell2 = Nothing
  End Sub

  Sub AddRow
    rowSeq = rowSeq + 1
    Dim container, newDiv, q, sid
    q = Chr(34)
    sid = rowSeq
    Set container = document.getElementById("rowsContainer")
    Set newDiv = document.createElement("div")
    newDiv.className = "row"
    newDiv.id = "row_" & sid
    newDiv.innerHTML = _
      "<span class=" & q & "row-num" & q & "></span>" & _
      "<input type=" & q & "text" & q & " class=" & q & "code-input" & q & _
        " id=" & q & "code_" & sid & q & _
        " placeholder=" & q & "완제품 코드" & q & _
        " onkeypress=" & q & "jsEnter(this)" & q & ">" & _
      "<input type=" & q & "text" & q & " class=" & q & "name-input" & q & _
        " id=" & q & "name_" & sid & q & _
        " placeholder=" & q & "완제품명" & q & _
        " onkeypress=" & q & "jsEnter(this)" & q & ">" & _
      "<input type=" & q & "text" & q & " class=" & q & "qty-input" & q & _
        " id=" & q & "qty_" & sid & q & _
        " placeholder=" & q & "수량" & q & _
        " onkeyup=" & q & "jsFmt(this)" & q & _
        " onkeypress=" & q & "jsEnter(this)" & q & ">" & _
      "<button class=" & q & "row-del" & q & _
        " onclick=" & q & "jsRemove(" & sid & ")" & q & ">x</button>"
    container.appendChild newDiv
    Renumber
  End Sub

  Sub RemoveRow(idx)
    Dim row, container
    Set row = document.getElementById("row_" & idx)
    If Not (row Is Nothing) Then
      Set container = row.parentNode
      container.removeChild row
      If container.children.length = 0 Then AddRow
      Renumber
    End If
  End Sub

  Sub Renumber
    Dim container, i
    Set container = document.getElementById("rowsContainer")
    For i = 0 To container.children.length - 1
      container.children(i).firstChild.innerText = (i + 1)
    Next
  End Sub

  Sub ClearAllRows
    Dim container
    Set container = document.getElementById("rowsContainer")
    Do While container.children.length > 0
      container.removeChild container.children(0)
    Loop
  End Sub

  Sub ApplyPaste
    Dim ta, txt, lines, i, line, parts, code, pname, qty
    Dim k, ch, cleanQty, added
    Set ta = document.getElementById("pasteArea")
    txt = ta.value
    If Trim(txt) = "" Then
      MsgBox "붙여넣을 데이터가 없습니다." & vbCrLf & "엑셀에서 세 열(코드, 제품명, 수량)을 복사한 뒤 위 영역에 붙여넣으세요.", vbExclamation, "알림"
      Exit Sub
    End If

    txt = Replace(txt, vbCrLf, vbLf)
    txt = Replace(txt, vbCr, vbLf)
    lines = Split(txt, vbLf)

    ClearAllRows

    added = 0
    For i = 0 To UBound(lines)
      line = lines(i)
      If Trim(line) <> "" Then
        ' 탭 구분 우선 (엑셀 기본). 탭이 없으면 공백으로 split (제품명 공백 케이스는 약함)
        If InStr(line, vbTab) > 0 Then
          parts = Split(line, vbTab)
        Else
          Dim ln2
          ln2 = Trim(line)
          Do While InStr(ln2, "  ") > 0
            ln2 = Replace(ln2, "  ", " ")
          Loop
          parts = Split(ln2, " ")
        End If

        code = ""
        pname = ""
        qty = ""

        ' 3개 컬럼 매핑: 첫 번째 = 코드, 마지막 = 수량(숫자), 중간 = 이름
        If UBound(parts) >= 0 Then code = Trim(parts(0))
        If UBound(parts) >= 2 Then
          qty = Trim(parts(UBound(parts)))
          ' 가운데 토큰들을 모두 이름으로 합침 (제품명에 공백 있는 경우 대비)
          Dim m, midParts
          midParts = ""
          For m = 1 To UBound(parts) - 1
            If midParts = "" Then
              midParts = Trim(parts(m))
            Else
              midParts = midParts & " " & Trim(parts(m))
            End If
          Next
          pname = midParts
        ElseIf UBound(parts) = 1 Then
          ' 2컬럼: 코드 + 수량 (이름 없음)
          qty = Trim(parts(1))
        End If

        If code <> "" Then
          AddRow
          document.getElementById("code_" & rowSeq).value = code
          document.getElementById("name_" & rowSeq).value = pname

          cleanQty = ""
          For k = 1 To Len(qty)
            ch = Mid(qty, k, 1)
            If ch >= "0" And ch <= "9" Then cleanQty = cleanQty & ch
          Next
          If cleanQty <> "" Then
            document.getElementById("qty_" & rowSeq).value = FormatNumber(CDbl(cleanQty), 0, -1, 0, -1)
          End If
          added = added + 1
        End If
      End If
    Next

    If added = 0 Then
      Dim r2
      For r2 = 1 To 5
        AddRow
      Next
      MsgBox "유효한 데이터를 인식하지 못했습니다.", vbExclamation, "알림"
      Exit Sub
    End If

    ta.value = ""
  End Sub

  Sub ClearPaste
    document.getElementById("pasteArea").value = ""
    document.getElementById("pasteArea").focus
  End Sub

  Sub FormatQtyField(field)
    Dim raw, i, ch, cleaned
    raw = field.value
    cleaned = ""
    For i = 1 To Len(raw)
      ch = Mid(raw, i, 1)
      If ch >= "0" And ch <= "9" Then cleaned = cleaned & ch
    Next
    If cleaned = "" Then
      field.value = ""
      Exit Sub
    End If
    Dim formatted
    formatted = FormatNumber(CDbl(cleaned), 0, -1, 0, -1)
    If field.value <> formatted Then
      field.value = formatted
      Dim rng
      Set rng = field.createTextRange()
      rng.collapse False
      rng.select
    End If
  End Sub

  Sub HandleRowEnter(field)
    If window.event.keyCode = 13 Then
      Dim row, container, inputs, i, idx, cls
      Set row = field.parentNode
      Set container = row.parentNode
      Set inputs = row.getElementsByTagName("input")
      cls = field.className

      If cls = "code-input" Then
        inputs(1).focus
      ElseIf cls = "name-input" Then
        inputs(2).focus
      Else
        ' qty 칸: 다음 행 코드로 이동
        idx = -1
        For i = 0 To container.children.length - 1
          If container.children(i).id = row.id Then
            idx = i
            Exit For
          End If
        Next
        Dim nextInputs
        If idx >= 0 And idx + 1 < container.children.length Then
          Set nextInputs = container.children(idx + 1).getElementsByTagName("input")
          nextInputs(0).focus
        Else
          AddRow
          Set nextInputs = container.children(container.children.length - 1).getElementsByTagName("input")
          nextInputs(0).focus
        End If
      End If
    End If
  End Sub

  Sub DoOK
    Dim fso, wshShell, tempPath, f
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set wshShell = CreateObject("WScript.Shell")
    tempPath = wshShell.ExpandEnvironmentStrings("%TEMP%") & "\bom_input.txt"

    Dim container, i, row, inputs, c, n, q, total
    Set container = document.getElementById("rowsContainer")
    Set f = fso.CreateTextFile(tempPath, True)
    total = 0
    For i = 0 To container.children.length - 1
      Set row = container.children(i)
      Set inputs = row.getElementsByTagName("input")
      c = Trim(inputs(0).value)
      n = Trim(inputs(1).value)
      q = Trim(Replace(inputs(2).value, ",", ""))
      If c <> "" Then
        ' 형식: code|qty|name
        f.WriteLine c & "|" & q & "|" & n
        total = total + 1
      End If
    Next
    f.Close
    Set f = Nothing

    If total = 0 Then
      If fso.FileExists(tempPath) Then fso.DeleteFile tempPath
      Dim flagPath0
      flagPath0 = wshShell.ExpandEnvironmentStrings("%TEMP%") & "\bom_done.flag"
      Dim ff0
      Set ff0 = fso.CreateTextFile(flagPath0, True)
      ff0.WriteLine "cancel"
      ff0.Close
      Set ff0 = Nothing
      MsgBox "입력된 코드가 없습니다.", vbExclamation, "알림"
      Set fso = Nothing
      Set wshShell = Nothing
      self.close
      Exit Sub
    End If

    Set fso = Nothing
    Set wshShell = Nothing
    self.close
  End Sub

  Sub DoCancel
    Dim fso, wshShell, flagPath
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set wshShell = CreateObject("WScript.Shell")
    flagPath = wshShell.ExpandEnvironmentStrings("%TEMP%") & "\bom_done.flag"
    Dim ff
    Set ff = fso.CreateTextFile(flagPath, True)
    ff.WriteLine "cancel"
    ff.Close
    Set ff = Nothing
    Set fso = Nothing
    Set wshShell = Nothing
    self.close
  End Sub
</script>

<script language="JScript">
  function jsApply()        { ApplyPaste();          }
  function jsClearPaste()   { ClearPaste();          }
  function jsAddRow()       { AddRow();              }
  function jsRemove(idx)    { RemoveRow(idx);        }
  function jsOK()           { DoOK();                }
  function jsCancel()       { DoCancel();            }
  function jsFmt(field)     { FormatQtyField(field); }
  function jsEnter(field)   { HandleRowEnter(field); }
</script>
</head>
<body>
  <h2>SAP BOM 조회 - 완제품 입력</h2>
  <div class="sub">엑셀에서 복사 후 붙여넣거나, 아래 칸에 직접 입력하세요</div>

  <div class="paste-section">
    <div class="paste-title">엑셀 붙여넣기</div>
    <div class="paste-help">엑셀 세 열(완제품 코드 / 완제품명 / 발주 수량)을 선택해 복사 → 아래 영역에 Ctrl+V</div>
    <textarea id="pasteArea" class="paste-area" placeholder="9XXXXXXX&#9;상품명 A&#9;1000&#10;9XXXXXXY&#9;상품명 B&#9;500&#10;..."></textarea>
    <div class="paste-row">
      <button class="paste-btn" onclick="jsApply()">붙여넣은 데이터로 채우기</button>
      <button class="paste-clear" onclick="jsClearPaste()">지우기</button>
    </div>
  </div>

  <div class="header-row">
    <span class="lbl" style="width:120px">완제품 코드</span>
    <span class="lbl" style="width:180px">완제품명</span>
    <span class="lbl" style="width:90px">발주 수량</span>
  </div>

  <div id="rowsContainer"></div>

  <div class="add-row-wrap">
    <button class="add-row-btn" onclick="jsAddRow()">+ 행 추가</button>
  </div>

  <div class="btns">
    <button class="btn btn-ok" onclick="jsOK()">실행</button>
    <button class="btn btn-cancel" onclick="jsCancel()">취소</button>
  </div>
</body>
</html>
